<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="750.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="NavigationController">
   <children>
      <Pane prefHeight="200.0" prefWidth="200.0" stylesheets="@style.css">
         <styleClass>
            <String fx:value="main-bg" />
            <String fx:value="root" />
         </styleClass>
      </Pane>
      <Pane fx:id="decorPane" prefHeight="200.0" prefWidth="200.0">
         <children>
            <SVGPath content="M 0,0 Q 150,200 300,0 T 600,0" fill="#ffb6b200" layoutY="350.0" stroke="#ffb6b24d" strokeWidth="15.0" />
            <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#d5e05880" height="30.0" rotate="45.0" stroke="TRANSPARENT" strokeType="INSIDE" width="120.0" x="-30.0" y="100.0" />
            <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#bcd7eb80" height="25.0" rotate="-10.0" stroke="TRANSPARENT" strokeType="INSIDE" width="100.0" x="500.0" y="600.0" />
         </children>
      </Pane>
      <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="50.0">
         <children>
            <Text fill="#d1828a" strokeType="OUTSIDE" strokeWidth="0.0" text="How to use your coloring book:">
               <font>
                  <Font name="Comic Sans MS Bold" size="34.0" />
               </font>
            </Text>
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="35.0">
               <children>
                  <HBox alignment="CENTER_LEFT" maxWidth="500.0" prefHeight="100.0" prefWidth="200.0" rotate="1.5" spacing="30.0">
                     <children>
                        <StackPane prefHeight="150.0" prefWidth="200.0">
                           <children>
                              <Rectangle arcHeight="5.0" arcWidth="5.0" fill="WHITE" height="160.0" stroke="TRANSPARENT" strokeType="INSIDE" width="160.0" />
                              <ImageView fitHeight="140.0" fitWidth="140.0" pickOnBounds="true" preserveRatio="true" />
                           </children>
                        </StackPane>
                        <VBox prefHeight="200.0" prefWidth="100.0">
                           <children>
                              <Text fill="#ff8b94" strokeType="OUTSIDE" strokeWidth="0.0" text="Step 1:">
                                 <font>
                                    <Font name="Comic Sans MS Bold" size="28.0" />
                                 </font>
                              </Text>
                              <Text fill="#d1828a" strokeType="OUTSIDE" strokeWidth="0.0" text="Click on a color &#10;from the palette.&#10;">
                                 <font>
                                    <Font name="Comic Sans MS Bold" size="20.0" />
                                 </font>
                              </Text>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <HBox alignment="CENTER_LEFT" layoutX="60.0" layoutY="30.0" maxWidth="500.0" prefHeight="100.0" prefWidth="200.0" rotate="-1.5" spacing="30.0">
                     <children>
                        <StackPane prefHeight="150.0" prefWidth="200.0">
                           <children>
                              <Rectangle arcHeight="5.0" arcWidth="5.0" fill="WHITE" height="160.0" stroke="TRANSPARENT" strokeType="INSIDE" width="160.0" />
                              <ImageView fitHeight="140.0" fitWidth="140.0" pickOnBounds="true" preserveRatio="true" />
                           </children>
                        </StackPane>
                        <VBox prefHeight="200.0" prefWidth="100.0">
                           <children>
                              <Text fill="#ff8b94" strokeType="OUTSIDE" strokeWidth="0.0" text="Step 2:">
                                 <font>
                                    <Font name="Comic Sans MS Bold" size="28.0" />
                                 </font>
                              </Text>
                              <Text fill="#d1828a" strokeType="OUTSIDE" strokeWidth="0.0" text="Click the corresponding &#10;number on your page.&#10;">
                                 <font>
                                    <Font name="Comic Sans MS Bold" size="20.0" />
                                 </font>
                              </Text>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </VBox>
            <Text fill="#ff8b94" rotate="2.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Step 3: Have fun!">
               <font>
                  <Font name="Comic Sans MS Bold" size="42.0" />
               </font>
            </Text>
            <Button mnemonicParsing="false" onAction="#handleNavigation" rotate="-2.5" styleClass="pink-button" stylesheets="@style.css" text="Start Drawing!" />
         </children>
      </VBox>
   </children>
</StackPane>
